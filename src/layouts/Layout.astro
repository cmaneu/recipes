---
import '../styles/global.css';
import LangSwitcher from '../components/LangSwitcher.astro';
import { type Locale } from '../i18n';

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  hrefs?: Record<Locale, string | null>;
}

const {
  title,
  description = 'Mes recettes de cuisine, en ligne de commande.',
  lang = 'en',
  hrefs,
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen px-4 py-6 sm:px-6 sm:py-10">
    <main class="mx-auto w-full max-w-3xl">
      <div class="overflow-hidden rounded-lg border border-term-border bg-term-panel shadow-2xl shadow-black/40">
        <!-- Windows 11 style title bar -->
        <div class="flex h-10 items-center border-b border-term-border bg-black/30">
          <span class="ml-4 flex-1 truncate text-xs text-term-dim">{title}</span>
          {hrefs && (
            <div class="mr-3">
              <LangSwitcher current={lang} hrefs={hrefs} />
            </div>
          )}
          <div class="flex h-full" aria-hidden="true">
            <span class="flex h-full w-11 select-none items-center justify-center text-xs text-term-dim transition-colors hover:bg-white/10">─</span>
            <span class="flex h-full w-11 select-none items-center justify-center text-xs text-term-dim transition-colors hover:bg-white/10">□</span>
            <span class="flex h-full w-11 select-none items-center justify-center text-xs text-term-dim transition-colors hover:bg-red-600 hover:text-white">✕</span>
          </div>
        </div>
        <div class="px-5 py-6 text-sm leading-relaxed sm:px-8 sm:py-8 sm:text-base">
          <slot />
        </div>
      </div>
      <footer class="mt-6 text-center text-xs text-term-dim">
        <a
          class="hover:text-term-green"
          href="https://github.com/cmaneu/recipes"
          >github.com/cmaneu/recipes</a
        >
      </footer>
    </main>
  </body>
</html>
